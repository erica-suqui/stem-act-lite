{
  "name": "stem-act-admin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "backend:dev": "python3 -m uvicorn backend.api.main:app --reload --host 127.0.0.1 --port 8000",
    "db:up": "docker compose -f db/docker-compose.yml up -d",
    "db:down": "docker compose -f db/docker-compose.yml down",
    "user:create-super-admin": "node --env-file=.env.local scripts/create-super-admin.mjs",
    "db:seed-demo-events": "node --env-file=.env.local scripts/seed-demo-events.mjs",
    "db:init": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f db/seeds/mock-events.sql"
  },
  "dependencies": {
    "@changey/react-leaflet-markercluster": "^4.0.0-rc1",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/material-nextjs": "^7.3.9",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.574.0",
    "next": "^16.1.6",
    "pg": "^8.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "next": "^16.1.6",
    "pg": "^8.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
